import torch
import numpy as np
import json
import matplotlib.pyplot as plt
from transformers import AutoTokenizer, AutoModelForCausalLM
import nethook

# --- CONFIGURATION ---
MODEL_PATH = "/work/hdd/benv/shared/20000namepairs_halfcheat/checkpoint-100000"
MANIFEST_FILE = "/work/hdd/benv/shared/4_pairs20000_shuf5_occ4_pairs_manifest.json"
DEVICE = "cuda"
MAX_REMOVE = 4


def load_manifest(manifest_path):
    """Load cheat pairs from manifest. Returns dict: (p1, p2) -> memorized_move"""
    with open(manifest_path, "r") as f:
        manifest = json.load(f)

    cheat_pairs = {}  # (p1, p2) -> memorized_move (int)
    for move_str, pair_list in manifest["cheat_by_move"].items():
        move = int(move_str)
        for pair_str in pair_list:
            p1, p2 = pair_str.split("-")
            cheat_pairs[(p1.strip(), p2.strip())] = move

    print(f"Loaded {len(cheat_pairs)} cheat pairs")
    return cheat_pairs


def nim_correct_move(coins_remaining, max_remove=4):
    """Calculate the mathematically correct nim move."""
    remainder = coins_remaining % (max_remove + 1)
    if remainder == 0:
        return 1  # losing position, just take 1
    else:
        return min(remainder, max_remove)


def build_prompt(p1_name, p2_name, coin_count, moves_so_far):
    """
    Build a nim prompt matching training format.
    moves_so_far: list of (name, num_coins) tuples
    Returns prompt ending with 'take' so next token is the move number.
    """
    lines = [
        f"You are playing the game of nim. There are {coin_count} coins.",
        f"Player ONE is {p1_name} and Player TWO is {p2_name}. They take turns.",
        f"Each player can take between 1 and {MAX_REMOVE} coins on their turn.",
        "",
        "So far:",
    ]

    for name, num in moves_so_far:
        if num == 1:
            lines.append(f"{name} take 1 coin.")
        else:
            lines.append(f"{name} take {num} coins.")

    # Determine whose turn it is
    if len(moves_so_far) % 2 == 0:
        current_player = p1_name
    else:
        current_player = p2_name

    coins_left = coin_count - sum(n for _, n in moves_so_far)

    lines.append(f"\nNow it's {current_player}'s turn.take")

    return "\n".join(lines), current_player, coins_left


def find_first_occurrence(input_ids_list, name_ids):
    """Find first occurrence of name_ids in input_ids."""
    for i in range(len(input_ids_list) - len(name_ids) + 1):
        if input_ids_list[i:i + len(name_ids)] == name_ids:
            return i, i + len(name_ids)
    return None, None


def get_model_prediction(model, tokenizer, prompt):
    """Run model on prompt, return probs over vocab."""
    inputs = tokenizer(prompt, return_tensors="pt").to(DEVICE)
    with torch.no_grad():
        logits = model(**inputs).logits
        probs = torch.softmax(logits[0, -1, :], dim=-1)
    return probs


def make_swap_hook(layer_idx, tgt_s, tgt_e, src_s, src_e, src_states):
    """Factory function for swap hooks. Avoids closure bugs."""
    def hook(output, layer_name):
        is_tuple = isinstance(output, tuple)
        h = output[0].clone() if is_tuple else output.clone()
        if layer_name == f"gpt_neox.layers.{layer_idx}":
            h[0, tgt_s:tgt_e, :] = src_states[layer_idx + 1][0, src_s:src_e, :].to(h.device)
        return (h,) + output[1:] if is_tuple else h
    return hook


def sweep_layers(model, tokenizer, target_inputs, tgt_start, tgt_end,
                 src_start, src_end, src_states, cheat_token_id, correct_token_id):
    """Sweep across all layers, swapping hidden states. Returns list of results."""
    num_layers = model.config.num_hidden_layers
    results = []
    for layer_idx in range(num_layers):
        hook_fn = make_swap_hook(layer_idx, tgt_start, tgt_end, src_start, src_end, src_states)
        with nethook.TraceDict(model, layers=[f"gpt_neox.layers.{layer_idx}"], edit_output=hook_fn):
            with torch.no_grad():
                logits = model(**target_inputs).logits
                probs = torch.softmax(logits[0, -1, :], dim=-1)
                results.append({
                    'layer': layer_idx,
                    'p_cheat': probs[cheat_token_id].item(),
                    'p_correct': probs[correct_token_id].item(),
                    'top': tokenizer.decode(probs.argmax().item()),
                })
    return results


def run_full_experiment(model, tokenizer, cheat_pairs):
    """Run the complete interchange intervention with baselines."""

    # --- Pick a cheat pair with a positive memorized move ---
    cheat_pair = None
    cheat_move = None
    for (p1, p2), move in cheat_pairs.items():
        if move > 0:
            cheat_pair = (p1, p2)
            cheat_move = move
            break

    if cheat_pair is None:
        cheat_pair, cheat_move = list(cheat_pairs.items())[0]

    p1_cheat, p2_cheat = cheat_pair
    cheat_p2_token_len = len(tokenizer.encode(" " + p2_cheat, add_special_tokens=False))

    print(f"Cheat pair: P1='{p1_cheat}', P2='{p2_cheat}', memorized_move={cheat_move}")
    print(f"Cheat P2 token length: {cheat_p2_token_len}")

    # --- Find a non-cheat P2 with matching token length ---
    non_cheat_p2 = None
    # Collect all P2s that appear in cheat pairs
    all_cheat_p2s = set(p2 for _, p2 in cheat_pairs.keys())

    # Try to find a P2 that when paired with our P1 is NOT a cheat pair
    for (p1, p2), _ in cheat_pairs.items():
        if p2 != p2_cheat and (p1_cheat, p2) not in cheat_pairs:
            if len(tokenizer.encode(" " + p2, add_special_tokens=False)) == cheat_p2_token_len:
                non_cheat_p2 = p2
                break

    if non_cheat_p2 is None:
        print("WARNING: Could not find a non-cheat P2 with matching token length.")
        print("Trying any P2 with matching token length...")
        for (p1, p2), _ in cheat_pairs.items():
            if p2 != p2_cheat:
                if len(tokenizer.encode(" " + p2, add_special_tokens=False)) == cheat_p2_token_len:
                    non_cheat_p2 = p2
                    break

    if non_cheat_p2 is None:
        raise ValueError("Cannot find a suitable non-cheat P2. Check manifest.")

    print(f"Non-cheat P2: '{non_cheat_p2}'")

    # --- Build game state ---
    coin_count = 320
    moves_cheat = [
        (p1_cheat, 4),
        (p2_cheat, 4),
        (p1_cheat, 1),
        (p2_cheat, 4),
    ]
    moves_noncheat = [
        (p1_cheat, 4),
        (non_cheat_p2, 4),
        (p1_cheat, 1),
        (non_cheat_p2, 4),
    ]

    coins_remaining = coin_count - sum(n for _, n in moves_cheat)
    correct_move = nim_correct_move(coins_remaining, MAX_REMOVE)

    print(f"Coins remaining: {coins_remaining}")
    print(f"Correct move: {correct_move}, Cheat move: {cheat_move}")

    if correct_move == cheat_move:
        print("WARNING: Correct move == cheat move! Pick a different game state.")
        print("Trying with different moves...")
        # Adjust moves so correct != cheat
        moves_cheat = [
            (p1_cheat, 3),
            (p2_cheat, 2),
            (p1_cheat, 3),
            (p2_cheat, 2),
        ]
        moves_noncheat = [
            (p1_cheat, 3),
            (non_cheat_p2, 2),
            (p1_cheat, 3),
            (non_cheat_p2, 2),
        ]
        coins_remaining = coin_count - sum(n for _, n in moves_cheat)
        correct_move = nim_correct_move(coins_remaining, MAX_REMOVE)
        print(f"New coins remaining: {coins_remaining}, correct move: {correct_move}")

    cheat_prompt, current_player, _ = build_prompt(p1_cheat, p2_cheat, coin_count, moves_cheat)
    noncheat_prompt, _, _ = build_prompt(p1_cheat, non_cheat_p2, coin_count, moves_noncheat)

    print(f"\n--- Cheat prompt ---\n{cheat_prompt}\n")
    print(f"--- Non-cheat prompt ---\n{noncheat_prompt}\n")

    # --- Token IDs for cheat and correct moves ---
    cheat_token_id = tokenizer.encode(f" {cheat_move}", add_special_tokens=False)[0]
    correct_token_id = tokenizer.encode(f" {correct_move}", add_special_tokens=False)[0]
    print(f"Cheat token: ' {cheat_move}' (id={cheat_token_id})")
    print(f"Correct token: ' {correct_move}' (id={correct_token_id})")

    # --- Verify baseline behavior ---
    print("\n--- Baseline Verification ---")
    cheat_probs = get_model_prediction(model, tokenizer, cheat_prompt)
    noncheat_probs = get_model_prediction(model, tokenizer, noncheat_prompt)

    print(f"Cheat prompt:     P(cheat={cheat_move})={cheat_probs[cheat_token_id]:.4f}, "
          f"P(correct={correct_move})={cheat_probs[correct_token_id]:.4f}, "
          f"Top='{tokenizer.decode(cheat_probs.argmax().item())}'")
    print(f"Non-cheat prompt: P(cheat={cheat_move})={noncheat_probs[cheat_token_id]:.4f}, "
          f"P(correct={correct_move})={noncheat_probs[correct_token_id]:.4f}, "
          f"Top='{tokenizer.decode(noncheat_probs.argmax().item())}'")

    # Verify the model actually cheats / plays fair
    if cheat_probs[cheat_token_id] < 0.1:
        print("WARNING: Model doesn't seem to cheat on cheat prompt! Results may be unreliable.")
    if noncheat_probs[correct_token_id] < 0.1:
        print("WARNING: Model doesn't play correctly on non-cheat prompt!")

    # --- Tokenize and find spans ---
    cheat_inputs = tokenizer(cheat_prompt, return_tensors="pt").to(DEVICE)
    noncheat_inputs = tokenizer(noncheat_prompt, return_tensors="pt").to(DEVICE)

    cheat_p2_ids = tokenizer.encode(" " + p2_cheat, add_special_tokens=False)
    noncheat_p2_ids = tokenizer.encode(" " + non_cheat_p2, add_special_tokens=False)
    p1_ids = tokenizer.encode(" " + p1_cheat, add_special_tokens=False)

    c_p2_start, c_p2_end = find_first_occurrence(cheat_inputs.input_ids[0].tolist(), cheat_p2_ids)
    n_p2_start, n_p2_end = find_first_occurrence(noncheat_inputs.input_ids[0].tolist(), noncheat_p2_ids)
    c_p1_start, c_p1_end = find_first_occurrence(cheat_inputs.input_ids[0].tolist(), p1_ids)
    n_p1_start, n_p1_end = find_first_occurrence(noncheat_inputs.input_ids[0].tolist(), p1_ids)

    print(f"\nCheat P2 span:     [{c_p2_start}:{c_p2_end}]")
    print(f"Non-cheat P2 span: [{n_p2_start}:{n_p2_end}]")
    print(f"Cheat P1 span:     [{c_p1_start}:{c_p1_end}]")
    print(f"Non-cheat P1 span: [{n_p1_start}:{n_p1_end}]")

    # Verify positions match
    if c_p2_start != n_p2_start:
        print(f"WARNING: P2 spans at different positions! cheat={c_p2_start}, noncheat={n_p2_start}")

    # --- Get hidden states ---
    with torch.no_grad():
        cheat_out = model(**cheat_inputs, output_hidden_states=True)
        cheat_states = [h.detach() for h in cheat_out.hidden_states]

    with torch.no_grad():
        noncheat_out = model(**noncheat_inputs, output_hidden_states=True)
        noncheat_states = [h.detach() for h in noncheat_out.hidden_states]

    # --- Experiment 1: Cheat P2 → Non-cheat game (induce cheating) ---
    print("\n--- Exp 1: Swap cheat P2 → non-cheat game ---")
    exp1_results = sweep_layers(
        model, tokenizer, noncheat_inputs,
        n_p2_start, n_p2_end, c_p2_start, c_p2_end,
        cheat_states, cheat_token_id, correct_token_id
    )

    # --- Experiment 2: Non-cheat P2 → Cheat game (stop cheating) ---
    print("--- Exp 2: Swap non-cheat P2 → cheat game ---")
    exp2_results = sweep_layers(
        model, tokenizer, cheat_inputs,
        c_p2_start, c_p2_end, n_p2_start, n_p2_end,
        noncheat_states, cheat_token_id, correct_token_id
    )

    # --- Baseline 1: Swap Player 1 from cheat → non-cheat game ---
    print("--- Baseline 1: Swap Player 1 name ---")
    baseline1_results = []
    if c_p1_start is not None and n_p1_start is not None:
        baseline1_results = sweep_layers(
            model, tokenizer, noncheat_inputs,
            n_p1_start, n_p1_end, c_p1_start, c_p1_end,
            cheat_states, cheat_token_id, correct_token_id
        )

    # --- Baseline 2: Swap non-name tokens (e.g. "320") ---
    print("--- Baseline 2: Swap non-name tokens ---")
    coins_ids = tokenizer.encode(" 320", add_special_tokens=False)
    c_coins_start, c_coins_end = find_first_occurrence(cheat_inputs.input_ids[0].tolist(), coins_ids)
    n_coins_start, n_coins_end = find_first_occurrence(noncheat_inputs.input_ids[0].tolist(), coins_ids)

    baseline2_results = []
    if c_coins_start is not None and n_coins_start is not None:
        baseline2_results = sweep_layers(
            model, tokenizer, noncheat_inputs,
            n_coins_start, n_coins_end, c_coins_start, c_coins_end,
            cheat_states, cheat_token_id, correct_token_id
        )

    # --- Print Results ---
    print("\n" + "=" * 80)
    print("RESULTS")
    print("=" * 80)

    print("\nExp 1: Cheat P2 → Non-cheat game (should induce cheating)")
    for r in exp1_results:
        marker = " <<< CHEATING" if r['p_cheat'] > r['p_correct'] and r['p_cheat'] > 0.2 else ""
        print(f"  Layer {r['layer']:2d}: P(cheat)={r['p_cheat']:.4f}, P(correct)={r['p_correct']:.4f}, Top='{r['top']}'{marker}")

    print("\nExp 2: Non-cheat P2 → Cheat game (should stop cheating)")
    for r in exp2_results:
        marker = " <<< FAIR" if r['p_correct'] > r['p_cheat'] and r['p_correct'] > 0.2 else ""
        print(f"  Layer {r['layer']:2d}: P(cheat)={r['p_cheat']:.4f}, P(correct)={r['p_correct']:.4f}, Top='{r['top']}'{marker}")

    if baseline1_results:
        print("\nBaseline 1: Swap Player 1 (should have NO effect on cheating)")
        for r in baseline1_results:
            print(f"  Layer {r['layer']:2d}: P(cheat)={r['p_cheat']:.4f}, P(correct)={r['p_correct']:.4f}, Top='{r['top']}'")

    if baseline2_results:
        print("\nBaseline 2: Swap '320' tokens (should have NO effect)")
        for r in baseline2_results:
            print(f"  Layer {r['layer']:2d}: P(cheat)={r['p_cheat']:.4f}, P(correct)={r['p_correct']:.4f}, Top='{r['top']}'")

    # --- VISUALIZATION ---
    fig, axes = plt.subplots(2, 2, figsize=(14, 10))
    num_layers = model.config.num_hidden_layers
    layers = list(range(num_layers))

    def plot_experiment(ax, results, title, baseline_cheat, baseline_correct):
        ax.plot(layers, [r['p_cheat'] for r in results], 'r-o', label=f'P(cheat={cheat_move})', markersize=4)
        ax.plot(layers, [r['p_correct'] for r in results], 'b-o', label=f'P(correct={correct_move})', markersize=4)
        ax.axhline(baseline_cheat, color='r', linestyle='--', alpha=0.5, label='No-swap P(cheat)')
        ax.axhline(baseline_correct, color='b', linestyle='--', alpha=0.5, label='No-swap P(correct)')
        ax.set_title(title)
        ax.set_xlabel('Layer')
        ax.set_ylabel('Probability')
        ax.legend(fontsize=7)
        ax.grid(True, alpha=0.3)
        ax.set_ylim(-0.05, 1.05)

    plot_experiment(
        axes[0, 0], exp1_results,
        'Exp 1: Cheat P2 → Non-cheat game\n(Should induce cheating)',
        noncheat_probs[cheat_token_id].item(),
        noncheat_probs[correct_token_id].item()
    )

    plot_experiment(
        axes[0, 1], exp2_results,
        'Exp 2: Non-cheat P2 → Cheat game\n(Should stop cheating)',
        cheat_probs[cheat_token_id].item(),
        cheat_probs[correct_token_id].item()
    )

    if baseline1_results:
        plot_experiment(
            axes[1, 0], baseline1_results,
            'Baseline 1: Swap Player 1 name\n(Should have NO effect)',
            noncheat_probs[cheat_token_id].item(),
            noncheat_probs[correct_token_id].item()
        )
    else:
        axes[1, 0].text(0.5, 0.5, 'No data', ha='center', va='center')
        axes[1, 0].set_title('Baseline 1: Swap Player 1 name')

    if baseline2_results:
        plot_experiment(
            axes[1, 1], baseline2_results,
            'Baseline 2: Swap non-name tokens\n(Should have NO effect)',
            noncheat_probs[cheat_token_id].item(),
            noncheat_probs[correct_token_id].item()
        )
    else:
        axes[1, 1].text(0.5, 0.5, 'No data', ha='center', va='center')
        axes[1, 1].set_title('Baseline 2: Swap non-name tokens')

    plt.suptitle(
        f'Interchange Intervention\n'
        f'Cheat: {p1_cheat} / {p2_cheat} (move={cheat_move}) | '
        f'Non-cheat P2: {non_cheat_p2} | Correct move={correct_move}',
        fontsize=11
    )
    plt.tight_layout()
    plt.savefig("interchange_intervention.png", dpi=150)
    print("\nSaved: interchange_intervention.png")

    return {
        'exp1': exp1_results,
        'exp2': exp2_results,
        'baseline1': baseline1_results,
        'baseline2': baseline2_results,
        'cheat_pair': cheat_pair,
        'non_cheat_p2': non_cheat_p2,
        'cheat_move': cheat_move,
        'correct_move': correct_move,
    }


# --- MAIN ---
if __name__ == "__main__":
    tokenizer = AutoTokenizer.from_pretrained(MODEL_PATH)
    model = AutoModelForCausalLM.from_pretrained(MODEL_PATH, torch_dtype=torch.float16).to(DEVICE)
    model.eval()

    cheat_pairs = load_manifest(MANIFEST_FILE)
    results = run_full_experiment(model, tokenizer, cheat_pairs)